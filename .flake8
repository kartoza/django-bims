# Flake8 configuration for Django BIMS

[flake8]
max-line-length = 120
max-complexity = 18
select = B,C,E,F,W,T4,B9
ignore =
    # line too long - handled by black
    E501,
    # line break before binary operator - conflicts with black
    W503,
    # whitespace before ':' - conflicts with black
    E203,
    # missing trailing comma - handled by black
    C812,
    # do not use bare 'except'
    E722,
    # continuation line indentation
    E125,
    E126,
    # no spaces around keyword / parameter equals
    E251,
    # too many blank lines
    E303,
    # name may be undefined, or defined from star imports
    F405,
    # legacy ignores
    W504,
    W605,
    F901

exclude =
    .git,
    .venv,
    venv,
    __pycache__,
    migrations,
    static,
    media,
    node_modules,
    .eggs,
    *.egg,
    build,
    dist,
    docs,
    .tox,
    .mypy_cache,
    .pytest_cache,
    .nox,
    deployment,
    *.min.js,
    *.min.css,
    webpack-stats.json,
    .pycharm_helpers,
    fabfile.py,
    secret.py,
    scripts,
    restore_geonode.py,
    geonode_queue_settings.py,
    pavement.py

per-file-ignores =
    # imported but unused - __init__.py files often have these
    __init__.py: F401
    # settings files can have wildcard imports
    */settings/*.py: F401,F403,F405
    # test files can have assertions and longer lines
    test_*.py: S101,E501
    tests/*.py: S101,E501
    # admin files often have unused imports
    */admin.py: F401
